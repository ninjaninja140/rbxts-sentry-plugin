{
	"name": "@nrbx/sentry-sdk",
	"description": "A Sentry SDK for Roblox TypeScript projects, forked & ported from devSparkle/sentry-roblox",
	"author": "ninjaninja140",
	"repository": {
		"type": "git",
		"url": "https://github.com/ninjaninja140/rbxts-sentry-plugin"
	},
	"version": "1.0.7",
	"main": "out/init.lua",
	"license": "MIT",
	"scripts": {
		"build": "rbxtsc",
		"watch": "rbxtsc -w",
		"biome": "biome check --write  --unsafe",
		"prepublishOnly": "yarn run build"
	},
	"types": "out/index.d.ts",
	"files": ["out", "README.md", "LICENSE.txt", "!**/*.tsbuildinfo"],
	"publishConfig": {
		"access": "public"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@rbxts/compiler-types": "^3.0.0-types.0",
		"@rbxts/types": "^1.0.925",
		"roblox-ts": "^3.0.0",
		"typescript": "^6.0.3"
	},
	"packageManager": "yarn@4.17.0",
	"dependencies": {
		"@rbxts/services": "^1.6.0"
	}
}
