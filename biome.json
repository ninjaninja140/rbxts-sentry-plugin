{
	"$schema": "https://biomejs.dev/schemas/latest/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false,
		"includes": ["./src/**/*", "./biome.json", "./package.json", "./tsconfig.json", "./default.project.json"]
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"formatter": {
		"enabled": true,
		"formatWithErrors": true,
		"indentStyle": "tab",
		"indentWidth": 4,
		"lineEnding": "crlf",
		"lineWidth": 120,
		"attributePosition": "auto",
		"bracketSameLine": false,
		"bracketSpacing": true,
		"expand": "auto",
		"useEditorconfig": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"security": { "noDangerouslySetInnerHtml": "off" },
			"performance": {
				"noAccumulatingSpread": "off"
			},
			"correctness": {
				"useImportExtensions": "off"
			},
			"style": {
				"noNonNullAssertion": "off"
			},
			"a11y": {
				"noStaticElementInteractions": "off",
				"useKeyWithClickEvents": "off",
				"noRedundantAlt": "off"
			},
			"suspicious": {
				"noUnknownAtRules": "off",
				"noEvolvingTypes": "error",
				"noArrayIndexKey": "off",
				"noExplicitAny": "off",
				"noUnsafeDeclarationMerging": "off",
				"noSelfCompare": "off",
				"noEmptyInterface": "off"
			},
			"complexity": { "noBannedTypes": "off" }
		}
	},
	"javascript": {
		"jsxRuntime": "reactClassic",
		"formatter": {
			"jsxQuoteStyle": "single",
			"quoteProperties": "asNeeded",
			"trailingCommas": "es5",
			"semicolons": "always",
			"arrowParentheses": "always",
			"bracketSameLine": false,
			"quoteStyle": "single",
			"attributePosition": "auto",
			"bracketSpacing": true
		}
	},
	"html": {
		"formatter": {
			"selfCloseVoidElements": "always"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "off"
			}
		}
	}
}
